# Client-side (safe to expose; used by the React app). Vite only exposes VITE_* vars.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Build script only (NEVER commit / never prefix with VITE_). Bypasses RLS to write data.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Optional: direct Postgres connection so the build applies supabase/schema.sql
# automatically (no manual SQL editor step). From Supabase: Connect → Session pooler.
# Format: postgresql://postgres.<ref>:<db-password>@<host>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=
